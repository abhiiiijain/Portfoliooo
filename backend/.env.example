# Backend — deploy on Render (project root: backend, see render.yaml)
PORT=4042

# MongoDB Atlas connection string
MONGODB_URI=
MONGODB_DB_NAME=portfolio

# Allowed browser origins for CORS (comma-separated, no trailing slash)
# Production Vercel site + local dev:
FRONTEND_URL=https://abhiiiijain.vercel.app,http://localhost:4041

# Or split across both vars:
# FRONTEND_URL=https://abhiiiijain.vercel.app
# ALLOWED_ORIGINS=http://localhost:4041

# Allow any *.vercel.app preview deployment (recommended)
ALLOW_VERCEL_PREVIEWS=true

# Admin auth
JWT_SECRET=
ADMIN_PASSWORD=

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: GitHub stats on homepage (higher rate limits)
# GITHUB_TOKEN=
