# Backend (Vercel project root: backend)
PORT=4042

# MongoDB Atlas connection string
MONGODB_URI=
MONGODB_DB_NAME=portfolio

# Production frontend URL (used for CORS + redirect from backend /)
FRONTEND_URL=http://localhost:4041

# Optional: comma-separated extra origins (staging domains, etc.)
# ALLOWED_ORIGINS=https://www.example.com

# Allow any *.vercel.app preview deployment to call the API (recommended for Vercel)
ALLOW_VERCEL_PREVIEWS=true

# Admin auth
JWT_SECRET=
ADMIN_PASSWORD=

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: GitHub stats on homepage (higher rate limits)
GITHUB_TOKEN=
