# Backend — deploy on Render (project root: backend, see render.yaml)
PORT=4042

# MongoDB Atlas connection string
MONGODB_URI=
MONGODB_DB_NAME=portfolio

# Vercel frontend URL (CORS only)
# Production: https://your-site.vercel.app or your custom domain
FRONTEND_URL=http://localhost:4041

# Optional: comma-separated extra origins (custom domains, etc.)
# ALLOWED_ORIGINS=https://www.example.com

# Allow Vercel preview deployments (*.vercel.app) to call this Render API
ALLOW_VERCEL_PREVIEWS=true

# Admin auth
JWT_SECRET=
ADMIN_PASSWORD=

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: GitHub stats on homepage (higher rate limits)
# GITHUB_TOKEN=
