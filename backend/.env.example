# Server (Next.js reads PORT automatically)
PORT=3001

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=portfolio

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Cloudinary — server-side only, never expose API secret to the frontend
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
